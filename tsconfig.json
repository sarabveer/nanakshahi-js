{
  "compilerOptions": {
    /* Base Options: */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    /* Strictness */
    "strict": true,
    "noImplicitOverride": true,

    /* Module Resolution */
    "module": "preserve",
    "noEmit": true,
    "lib": ["es2022"]
  },
  "include": ["index.ts", "src/**/*.ts"]
}
